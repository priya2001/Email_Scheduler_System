{
  "name": "email-scheduler-backend",
  "version": "1.0.0",
  "description": "Production-grade Email Scheduler Service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "email",
    "scheduler",
    "bullmq",
    "redis",
    "typescript"
  ],
  "author": "ReachInbox",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "bullmq": "^5.75.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "html-to-text": "^9.0.5",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "prisma": "^5.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
