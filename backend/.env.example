# Server
NODE_ENV=development
PORT=3001

# Database - PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/email_scheduler?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=email_scheduler

# SMTP - Ethereal Email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_email@ethereal.email
SMTP_PASSWORD=your_ethereal_password

# API
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# Features
MAX_EMAILS_PER_HOUR=100
MIN_DELAY_BETWEEN_EMAILS=2000
WORKER_CONCURRENCY=5
